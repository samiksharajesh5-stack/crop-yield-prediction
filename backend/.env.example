# ── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Neon PostgreSQL Database ─────────────────────────────────────────────────
# Get from: console.neon.tech → your project → Connect → Connection string
# RULES: No quotes, no &channel_binding=require at end
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-XXXX.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# ── JWT Secret ────────────────────────────────────────────────────────────────
# Any long random string (min 32 chars)
JWT_SECRET=change_this_to_any_long_random_string_abcdef123456
JWT_EXPIRES_IN=7d

# ── OpenWeather API (free at openweathermap.org/api) ─────────────────────────
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
